   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "# 1. Load Data\n",
    "print(\"Extracting behavioral records for Customer Churn Pipeline...\")\n",
    "file_path = r\"C:\\Users\\NITIN CHHABRA\\Documents\\Week1_NLP_Internship\\Data\\Reviews.csv\"\n",
    "df = pd.read_csv(file_path, nrows=5000)\n",
    "\n",
    "# Fill missing components safely\n",
    "df['Text'] = df['Text'].fillna('')\n",
    "df['Datetime'] = pd.to_datetime(df['Time'], unit='s')\n",
    "df['Year'] = df['Datetime'].dt.year\n",
    "\n",
    "# =========================================================\n",
    "# STEP 2: METRICS FEATURE ENGINEERING (Behavior Tracking)\n",
    "# =========================================================\n",
    "# Group data by user to map corporate loyalty tracking\n",
    "user_metrics = df.groupby('UserId').agg(\n",
    "    Total_Orders=('ProductId', 'count'),\n",
    "    Avg_Rating=('Score', 'mean'),\n",
    "    Latest_Active_Year=('Year', 'max')\n",
    ").reset_index()\n",
    "\n",
    "# Defining Churn Constraints: \n",
    "# If a customer hasn't purchased post-2010 OR their average rating is critically low (<=2.0), they are high churn risks.\n",
    "def evaluate_churn_risk(row):\n",
    "    if row['Latest_Active_Year'] <= 2010 or row['Avg_Rating'] <= 2.0:\n",
    "        return 'Churned'\n",
    "    return 'Active'\n",
    "\n",
    "user_metrics['Churn_Status'] = user_metrics.apply(evaluate_churn_risk, axis=1)\n",
    "\n",
    "# =========================================================\n",
    "# STEP 3: DATA VISUALIZATIONS\n",
    "# =========================================================\n",
    "# Plot 1: Churn Density Proportions\n",
    "plt.figure(figsize=(6, 5))\n",
    "sns.countplot(x='Churn_Status', data=user_metrics, palette='Set2')\n",
    "plt.title('Customer Retention vs Churn Distribution', fontsize=14, fontweight='bold')\n",
    "plt.xlabel('Customer Retention Profile')\n",
    "plt.ylabel('Unique User Base Count')\n",
    "plt.savefig('customer_churn_distribution.png', bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "# Plot 2: Rating Behavior vs Churn Correlation\n",
    "plt.figure(figsize=(8, 5))\n",
    "sns.boxplot(x='Churn_Status', y='Avg_Rating', data=user_metrics, palette='pastel')\n",
    "plt.title('User Rating Threshold Dynamics across Churn Matrix', fontsize=12, fontweight='bold')\n",
    "plt.xlabel('Retention Profile')\n",
    "plt.ylabel('Average Account Rating (1-5 Scale)')\n",
    "plt.savefig('churn_rating_correlation.png', bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "# 4. Save Clean Analytics Layer\n",
    "output_name = \"Customer_Churn_Analysis_Report.csv\"\n",
    "user_metrics.to_csv(output_name, index=False)\n",
    "print(f\"\\nSuccess! Churn matrix exported safely as '{output_name}'\")"
   ]
  },
